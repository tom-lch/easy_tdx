{
  "schemaVersion": 1,
  "layers": [
    {
      "id": "layer:protocol-codec",
      "name": "Protocol Codec Layer",
      "description": "Low-level binary encoders/decoders for the 通达信 (TongDaXin) TCP wire protocol. Handles the 16-byte frame header (magic=0x0074CBB1, ZipFlag, SeqID, Method, zipsize, unzipsize), zlib body decompression, variable-length signed price encoding, 4-byte volume custom float format, and the 10-byte MAC protocol request frame. Pure parsing functions — no I/O.",
