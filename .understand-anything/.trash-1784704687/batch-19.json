      "name": "bias_reversal.py",
      "filePath": "strategies/bias_reversal.py",
      "summary": "BIAS (乖离率) reversal strategy: buys when 6-day BIAS drops below -3% (oversold) and exits when it rises above +3% (overbought). Suitable for range-bound markets. Defined as BIAStrategy subclass of Strategy.",
      "complexity": 3,
      "tags": ["strategy", "bias", "reversal", "oscillator", "range-bound"]
    },
    {
      "id": "class:strategies/bias_reversal.py:BIAStrategy",
      "type": "class",
      "name": "BIAStrategy",
      "filePath": "strategies/bias_reversal.py",
      "summary": "Strategy subclass that buys on BIAS6<-3% (oversold) and sells on BIAS6>+3% (overbought). Uses MyTT.BIAS with period=6; only the BIAS6 array is retained.",
      "complexity": 3,
      "tags": ["strategy", "class", "reversal", "bias"]
    },
    {
      "id": "file:strategies/bollinger_breakout.py",
