      "name": "bollinger_breakout.py",
      "filePath": "strategies/bollinger_breakout.py",
      "summary": "Bollinger Bands breakout strategy: buys when close breaks below the lower band, sells when close breaks above the upper band. Counter-trend mean-reversion in a range-bound regime.",
      "complexity": 3,
      "tags": ["strategy", "bollinger", "mean-reversion", "range-bound"]
    },
