      "summary": "Strategy subclass that trades Bollinger Band edges. Uses MyTT.BOLL with period=20 returning (upper, mid, lower); mid is unused.",
      "complexity": 3,
      "tags": ["strategy", "class", "bollinger", "mean-reversion"]
    },
